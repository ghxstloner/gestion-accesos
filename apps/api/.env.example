# ── Application ──
NODE_ENV=development
PORT=4000

# ── Database (MySQL 8 via Docker Compose) ──
DATABASE_URL="mysql://root:root@localhost:3306/sga_dev"
DATABASE_URL_TEST="mysql://root:root@localhost:3306/sga_test"

# ── Authentication ──
JWT_ACCESS_SECRET=change-me-access-secret-in-production
JWT_REFRESH_SECRET=change-me-refresh-secret-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Security ──
CORS_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost

# ── File storage ──
STORAGE_PATH=./storage
MAX_FILE_SIZE=10485760
