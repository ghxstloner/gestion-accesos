// SGA — Sistema de Gestión de Accesos
// Prisma schema (MySQL 8) — built incrementally per bounded context.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  RESIDENCE_ID
  OTHER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING_ACTIVATION
}

enum RoleCode {
  SYSTEM_ADMIN
  COMPANY_ADMIN
  APPLICANT
  DOCUMENT_RECEIVER
  ACCESS_DOCUMENTS_MANAGER
  CARD_ISSUER
}

enum AuthorizedSignerStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  UNDER_DOCUMENT_REVIEW
  RETURNED_FOR_CORRECTION
  DOCUMENTS_APPROVED
  PENDING_FINAL_APPROVAL
  APPROVED
  REJECTED
  IN_PRODUCTION
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum RequestType {
  PERMANENT_CARD
  TEMPORARY_PERSON
  TEMPORARY_VEHICLE
  TEMPORARY_EQUIPMENT
}

enum RequestParticipantRole {
  PRIMARY
  BENEFICIARY
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskType {
  DOCUMENT_REVIEW
  FINAL_APPROVAL
}

enum TaskStatus {
  PENDING
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum CatalogKind {
  REQUEST_TYPE
  IDENTIFICATION_TYPE
  DOCUMENT_TYPE
  ACCESS_POINT
  SECURITY_ZONE
  ACCESS_AREA
  REJECTION_REASON
  GENDER
  MARITAL_STATUS
  BLOOD_TYPE
  NATIONALITY
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  REPLACED
}

enum DocumentSubjectType {
  REQUEST
  USER
}

enum CredentialType {
  PERMANENT_CARD
  TEMPORARY_PERSON_PASS
  TEMPORARY_VEHICLE_PASS
  TEMPORARY_EQUIPMENT_PASS
}

enum CredentialStatus {
  PENDING_PRODUCTION
  IN_PRODUCTION
  READY_FOR_DELIVERY
  DELIVERED
  SUSPENDED
  REVOKED
  EXPIRED
  CANCELLED
}

enum EventType {
  CREATED
  SUBMITTED
  RESUBMITTED
  ASSIGNED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  STAGE_APPROVED
  RETURNED
  REJECTED
  APPROVED
  STARTED_PRODUCTION
  MARKED_READY
  DELIVERED
  REVERTED_PRODUCTION
  RETURNED_TO_PRODUCTION
  CORRECTED_DELIVERY
  CANCELLED
  REVOKED_SIGNER
  DEACTIVATED
  SUSPENDED
  ACTIVATED
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  RETIRED
}

enum WorkflowInstanceStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum WorkflowNodeInstanceStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum WorkflowTaskStatus {
  PENDING
  CLAIMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum WorkflowAssignmentType {
  ROLE
  USER
}

// ─────────────────────────────────────────────
// 1. ORGANIZATIONS
// ─────────────────────────────────────────────

model Company {
  id              String        @id @default(uuid())
  legalName       String        @map("legal_name") @db.VarChar(255)
  tradeName       String?       @map("trade_name") @db.VarChar(255)
  taxIdentifier   String?       @unique @map("tax_identifier") @db.VarChar(50)
  email           String?       @db.VarChar(255)
  phone           String?       @db.VarChar(50)
  address         String?       @db.Text
  logoUrl         String?       @map("logo_url") @db.VarChar(512)
  mainContactName String?       @map("main_contact_name") @db.VarChar(255)
  status          CompanyStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  users             User[]
  authorizedSigners CompanyAuthorizedSigner[]
  requests          Request[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// 2. IDENTITY AND AUTHENTICATION
// ─────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  code        RoleCode @unique
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolesPermissions RolePermission[]
  users            UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  rolesPermissions RolePermission[]
  usersPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                       String       @id @default(uuid())
  documentType             DocumentType @default(NATIONAL_ID) @map("document_type")
  documentNumber           String       @map("document_number") @db.VarChar(50)
  normalizedDocumentNumber String       @map("normalized_document_number") @db.VarChar(50)

  firstName                String       @map("first_name") @db.VarChar(100)
  middleName               String?      @map("middle_name") @db.VarChar(100)
  lastName                 String       @map("last_name") @db.VarChar(100)
  secondLastName           String?      @map("second_last_name") @db.VarChar(100)
  marriedLastName          String?      @map("married_last_name") @db.VarChar(100)

  birthDate                DateTime?    @map("birth_date")
  gender                   String?      @db.VarChar(20)
  maritalStatus            String?      @map("marital_status") @db.VarChar(30)
  nationality              String?      @db.VarChar(80)
  bloodType                String?      @map("blood_type") @db.VarChar(5)
  phone                    String?      @db.VarChar(50)
  mobile                   String?      @db.VarChar(50)
  email                    String?      @db.VarChar(255)
  emailVerifiedAt          DateTime?    @map("email_verified_at")
  residentialAddress       String?      @map("residential_address") @db.Text
  physicalCondition        String?      @map("physical_condition") @db.VarChar(255)

  companyId                String?      @map("company_id")
  department               String?      @db.VarChar(120)
  position                 String?      @db.VarChar(120)
  employeeNumber           String?      @map("employee_number") @db.VarChar(50)
  socialSecurityNumber     String?      @map("social_security_number") @db.VarChar(50)
  photoUrl                 String?      @map("photo_url") @db.VarChar(512)

  status                   UserStatus   @default(ACTIVE)
  createdBy                String?      @map("created_by") @db.VarChar(36)
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  company              Company?                  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  authIdentity         AuthIdentity?
  userRoles            UserRole[]
  userPermissions      UserPermission[]
  refreshSessions      RefreshSession[]
  createdRequests      Request[]                 @relation("RequestCreator")
  requestParticipations RequestParticipant[]     @relation("UserRequestParticipant")
  authorizedSignatures CompanyAuthorizedSigner[] @relation("UserAuthorizedSigner")
  credentials          Credential[]              @relation("UserCredential")
  custodyRecords       CustodyRecord[]           @relation("UserCustody")
  recoveryChallenges   PasswordRecoveryChallenge[]
  notifications        Notification[]
  workflowDefinitionsCreated WorkflowDefinition[] @relation("WorkflowDefinitionCreator")
  workflowVersionsCreated   WorkflowVersion[]    @relation("WorkflowVersionCreator")
  workflowVersionsPublished WorkflowVersion[]    @relation("WorkflowVersionPublisher")

  @@unique([documentType, normalizedDocumentNumber])
  @@index([companyId])
  @@index([email])
  @@index([firstName, lastName])
  @@index([status])
  @@map("users")
}

model AuthIdentity {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  passwordChangedAt   DateTime  @default(now()) @map("password_changed_at")
  lastLoginAt         DateTime? @map("last_login_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_identities")
}

model PasswordRecoveryChallenge {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  codeHash        String    @map("code_hash") @db.VarChar(255)
  expiresAt       DateTime  @map("expires_at")
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3) @map("max_attempts")
  consumedAt      DateTime? @map("consumed_at")
  invalidatedAt   DateTime? @map("invalidated_at")
  requestedIpHash String?   @map("requested_ip_hash") @db.VarChar(64)
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_recovery_challenges")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserPermission {
  userId       String   @map("user_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model SystemSetting {
  id           String   @id @default("global") @db.VarChar(32)
  companyName  String   @default("Gestión de Accesos") @map("company_name") @db.VarChar(255)
  logoUrl      String?  @map("logo_url") @db.VarChar(512)
  smtpHost     String?  @map("smtp_host") @db.VarChar(255)
  smtpPort     Int      @default(587) @map("smtp_port")
  smtpSecurity String   @default("TLS") @map("smtp_security") @db.VarChar(16)
  smtpUsername String?  @map("smtp_username") @db.VarChar(255)
  smtpPassword String?  @map("smtp_password") @db.VarChar(512)
  fromEmail    String?  @map("from_email") @db.VarChar(255)
  fromName     String?  @map("from_name") @db.VarChar(255)
  replyToEmail String?  @map("reply_to_email") @db.VarChar(255)
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model RefreshSession {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  userAgent String?   @map("user_agent") @db.Text
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_sessions")
}

// ─────────────────────────────────────────────
// 3. AUTHORIZED SIGNERS
// ─────────────────────────────────────────────

model CompanyAuthorizedSigner {
  id                      String                 @id @default(uuid())
  companyId               String                 @map("company_id")
  signerUserId            String                 @map("signer_user_id")
  position                String                 @db.VarChar(120)
  validFrom               DateTime               @map("valid_from")
  validUntil              DateTime?              @map("valid_until")
  authorizationDocumentId String?                @map("authorization_document_id") @db.VarChar(36)
  signatureFileId         String?                @map("signature_file_id") @db.VarChar(36)
  status                  AuthorizedSignerStatus @default(ACTIVE)
  revokedAt               DateTime?              @map("revoked_at")
  revokedBy               String?                @map("revoked_by") @db.VarChar(36)
  revocationReason        String?                @map("revocation_reason") @db.Text
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  signerUser User      @relation("UserAuthorizedSigner", fields: [signerUserId], references: [id], onDelete: Restrict)
  requests   Request[]

  @@index([companyId])
  @@index([signerUserId])
  @@index([status])
  @@map("company_authorized_signers")
}

// ─────────────────────────────────────────────
// 4. CATALOGS
// ─────────────────────────────────────────────

model CatalogItem {
  id             String      @id @default(uuid())
  kind           CatalogKind
  code           String      @db.VarChar(80)
  name           String      @db.VarChar(200)
  description    String?     @db.Text
  isActive       Boolean     @default(true) @map("is_active")
  displayOrder   Int         @default(0) @map("display_order")
  parentZoneCode String?     @map("parent_zone_code") @db.VarChar(40)
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  requestTypeRequests      Request[]             @relation("RequestType")
  accessPointRequests      RequestAccessPoint[]
  accessAreaRequests       RequestAccessArea[]
  documentRequestDocuments RequestDocument[]
  documentRequirementTypes DocumentRequirement[] @relation("DocumentRequirementRequestType")
  documentRequirementDocs  DocumentRequirement[] @relation("DocumentRequirementDocumentType")
  rejectionReasonRequests  Request[]             @relation("RequestRejectionReason")

  @@unique([kind, code])
  @@index([kind, isActive, displayOrder])
  @@map("catalog_items")
}

// ─────────────────────────────────────────────
// 5. ACCESS REQUESTS
// ─────────────────────────────────────────────

model Request {
  id                 String        @id @default(uuid())
  requestNumber      String?       @unique @map("request_number") @db.VarChar(30)
  companyId          String        @map("company_id")
  requestTypeId      String        @map("request_type_id")
  createdByUserId    String        @map("created_by_user_id")
  createdByCompanyId String?       @map("created_by_company_id")
  authorizedSignerId String?       @map("authorized_signer_id")
  rejectionReasonId  String?       @map("rejection_reason_id")
  reason             String        @db.Text
  serviceCompanyName String?       @map("service_company_name") @db.VarChar(255)
  validFrom          DateTime?     @map("valid_from")
  validUntil         DateTime?     @map("valid_until")
  scheduleFrom       String?       @map("schedule_from") @db.VarChar(10)
  scheduleUntil      String?       @map("schedule_until") @db.VarChar(10)
  observations       String?       @db.Text
  status             RequestStatus @default(DRAFT)
  version            Int           @default(1)
  submittedAt        DateTime?     @map("submitted_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requestType      CatalogItem              @relation("RequestType", fields: [requestTypeId], references: [id], onDelete: Restrict)
  createdByUser    User                     @relation("RequestCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  authorizedSigner CompanyAuthorizedSigner? @relation(fields: [authorizedSignerId], references: [id], onDelete: SetNull)
  rejectionReason  CatalogItem?             @relation("RequestRejectionReason", fields: [rejectionReasonId], references: [id], onDelete: SetNull)
  participants     RequestParticipant[]
  vehicles         RequestVehicle[]
  equipment        RequestEquipment[]
  accessPoints     RequestAccessPoint[]
  accessAreas      RequestAccessArea[]
  documents        RequestDocument[]
  submissions      RequestSubmission[]
  events           RequestEvent[]
  reviewTasks      ReviewTask[]
  credential       Credential?
  workflowInstance WorkflowInstance?

  @@index([companyId])
  @@index([status])
  @@index([requestTypeId])
  @@index([createdByUserId])
  @@index([createdAt])
  @@map("requests")
}

model RequestParticipant {
  id                     String                 @id @default(uuid())
  requestId              String                 @map("request_id")
  participantUserId      String                 @map("participant_user_id")
  role                   RequestParticipantRole @default(PRIMARY)
  personalEmergency      Boolean                @default(false) @map("personal_emergency")
  usePreviousPhoto       Boolean                @default(false) @map("use_previous_photo")
  departmentSnapshot     String?                @map("department_snapshot") @db.VarChar(120)
  positionSnapshot       String?                @map("position_snapshot") @db.VarChar(120)
  companyNameSnapshot    String?                @map("company_name_snapshot") @db.VarChar(255)
  identificationSnapshot String?                @map("identification_snapshot") @db.VarChar(120)
  fullNameSnapshot       String?                @map("full_name_snapshot") @db.VarChar(255)
  createdAt              DateTime               @default(now()) @map("created_at")

  request         Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  participantUser User    @relation("UserRequestParticipant", fields: [participantUserId], references: [id], onDelete: Restrict)

  @@unique([requestId, participantUserId])
  @@index([requestId])
  @@map("request_participants")
}

model RequestVehicle {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  brand       String   @db.VarChar(120)
  model       String   @db.VarChar(120)
  plateNumber String   @map("plate_number") @db.VarChar(50)
  color       String?  @db.VarChar(50)
  year        Int?
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, plateNumber])
  @@index([requestId])
  @@map("request_vehicles")
}

model RequestEquipment {
  id            String   @id @default(uuid())
  requestId     String   @map("request_id")
  brand         String?  @db.VarChar(120)
  equipmentType String   @map("equipment_type") @db.VarChar(120)
  serialNumber  String?  @map("serial_number") @db.VarChar(100)
  description   String?  @db.Text
  quantity      Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, serialNumber])
  @@index([requestId])
  @@map("request_equipment")
}

model RequestAccessPoint {
  id            String   @id @default(uuid())
  requestId     String   @map("request_id")
  accessPointId String   @map("access_point_id")
  createdAt     DateTime @default(now()) @map("created_at")

  request     Request     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  accessPoint CatalogItem @relation(fields: [accessPointId], references: [id], onDelete: Restrict)

  @@unique([requestId, accessPointId])
  @@index([requestId])
  @@map("request_access_points")
}

model RequestAccessArea {
  id            String       @id @default(uuid())
  requestId     String       @map("request_id")
  accessAreaId  String       @map("access_area_id")
  justification String?      @db.Text
  reviewStatus  ReviewStatus @default(PENDING) @map("review_status")
  reviewedBy    String?      @map("reviewed_by") @db.VarChar(36)
  reviewedAt    DateTime?    @map("reviewed_at")
  reviewComment String?      @map("review_comment") @db.Text
  createdAt     DateTime     @default(now()) @map("created_at")

  request    Request     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  accessArea CatalogItem @relation(fields: [accessAreaId], references: [id], onDelete: Restrict)

  @@unique([requestId, accessAreaId])
  @@index([requestId])
  @@index([reviewStatus])
  @@map("request_access_areas")
}

// ─────────────────────────────────────────────
// 6. DOCUMENTS
// ─────────────────────────────────────────────

model RequestDocument {
  id               String              @id @default(uuid())
  requestId        String              @map("request_id")
  documentTypeId   String              @map("document_type_id")
  subjectType      DocumentSubjectType @map("subject_type")
  subjectId        String?             @map("subject_id") @db.VarChar(36)
  currentVersionId String?             @map("current_version_id") @db.VarChar(36)
  status           DocumentStatus      @default(PENDING)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  request      Request           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  documentType CatalogItem       @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  versions     DocumentVersion[]
  reviews      DocumentReview[]

  @@index([requestId])
  @@index([status])
  @@map("request_documents")
}

model DocumentVersion {
  id                String   @id @default(uuid())
  requestDocumentId String   @map("request_document_id")
  versionNumber     Int      @map("version_number")
  originalFilename  String   @map("original_filename") @db.VarChar(255)
  storedFilename    String   @map("stored_filename") @db.VarChar(255)
  storageKey        String   @map("storage_key") @db.VarChar(512)
  mimeType          String   @map("mime_type") @db.VarChar(100)
  size              BigInt
  sha256            String   @db.VarChar(64)
  uploadedBy        String   @map("uploaded_by") @db.VarChar(36)
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  requestDocument RequestDocument  @relation(fields: [requestDocumentId], references: [id], onDelete: Cascade)
  reviews         DocumentReview[]

  @@unique([requestDocumentId, versionNumber])
  @@index([requestDocumentId])
  @@index([sha256])
  @@map("document_versions")
}

model DocumentReview {
  id                String       @id @default(uuid())
  requestDocumentId String       @map("request_document_id")
  documentVersionId String       @map("document_version_id")
  decision          ReviewStatus
  comment           String?      @db.Text
  reviewedBy        String       @map("reviewed_by") @db.VarChar(36)
  reviewedAt        DateTime     @default(now()) @map("reviewed_at")

  requestDocument RequestDocument @relation(fields: [requestDocumentId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)

  @@index([requestDocumentId])
  @@index([documentVersionId])
  @@map("document_reviews")
}

model DocumentRequirement {
  id             String              @id @default(uuid())
  requestTypeId  String              @map("request_type_id")
  documentTypeId String              @map("document_type_id")
  subjectType    DocumentSubjectType @map("subject_type")
  isRequired     Boolean             @default(true) @map("is_required")
  minFiles       Int                 @default(1) @map("min_files")
  maxFiles       Int                 @default(10) @map("max_files")
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  requestType  CatalogItem @relation("DocumentRequirementRequestType", fields: [requestTypeId], references: [id], onDelete: Cascade)
  documentType CatalogItem @relation("DocumentRequirementDocumentType", fields: [documentTypeId], references: [id], onDelete: Cascade)

  @@unique([requestTypeId, documentTypeId, subjectType])
  @@index([requestTypeId])
  @@map("document_requirements")
}

model FileMetadata {
  id               String   @id @default(uuid())
  storageKey       String   @unique @map("storage_key") @db.VarChar(512)
  originalFilename String   @map("original_filename") @db.VarChar(255)
  storedFilename   String   @map("stored_filename") @db.VarChar(255)
  mimeType         String   @map("mime_type") @db.VarChar(100)
  size             BigInt
  sha256           String   @db.VarChar(64)
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("file_metadata")
}

// ─────────────────────────────────────────────
// 7. SUBMISSION SNAPSHOTS
// ─────────────────────────────────────────────

model RequestSubmission {
  id                   String   @id @default(uuid())
  requestId            String   @map("request_id")
  sequence             Int
  submittedBy          String   @map("submitted_by") @db.VarChar(36)
  submittedAt          DateTime @default(now()) @map("submitted_at")
  snapshotJson         Json     @map("snapshot_json")
  snapshotHash         String   @map("snapshot_hash") @db.VarChar(64)
  previousSubmissionId String?  @map("previous_submission_id") @db.VarChar(36)

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, sequence])
  @@index([requestId])
  @@map("request_submissions")
}

// ─────────────────────────────────────────────
// 8. WORKFLOW: EVENTS AND REVIEW TASKS
// ─────────────────────────────────────────────

model RequestEvent {
  id             String         @id @default(uuid())
  requestId      String         @map("request_id")
  eventType      EventType      @map("event_type")
  fromStatus     RequestStatus? @map("from_status")
  toStatus       RequestStatus  @map("to_status")
  actorUserId    String?        @map("actor_user_id") @db.VarChar(36)
  actorRoleCode  String?        @map("actor_role_code") @db.VarChar(60)
  actorCompanyId String?        @map("actor_company_id") @db.VarChar(36)
  reasonCode     String?        @map("reason_code") @db.VarChar(80)
  comment        String?        @db.Text
  metadata       Json?
  ipAddress      String?        @map("ip_address") @db.VarChar(45)
  userAgent      String?        @map("user_agent") @db.Text
  correlationId  String?        @map("correlation_id") @db.VarChar(36)
  occurredAt     DateTime       @default(now()) @map("occurred_at")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, occurredAt])
  @@index([actorUserId])
  @@index([eventType])
  @@map("request_events")
}

model ReviewTask {
  id               String     @id @default(uuid())
  requestId        String     @map("request_id")
  taskType         TaskType   @map("task_type")
  status           TaskStatus @default(PENDING)
  assignedToUserId String?    @map("assigned_to_user_id") @db.VarChar(36)
  assignedRoleCode String?    @map("assigned_role_code") @db.VarChar(60)
  createdAt        DateTime   @default(now()) @map("created_at")
  assignedAt       DateTime?  @map("assigned_at")
  completedAt      DateTime?  @map("completed_at")
  dueAt            DateTime?  @map("due_at")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status])
  @@index([assignedToUserId])
  @@map("review_tasks")
}

// ─────────────────────────────────────────────
// 9. CREDENTIAL ISSUANCE & CUSTODY
// ─────────────────────────────────────────────

model Credential {
  id               String           @id @default(uuid())
  credentialNumber String           @unique @map("credential_number") @db.VarChar(30)
  requestId        String           @unique @map("request_id")
  credentialType   CredentialType   @map("credential_type")
  subjectUserId    String?          @map("subject_user_id") @db.VarChar(36)
  status           CredentialStatus @default(PENDING_PRODUCTION)
  issuedAt         DateTime?        @map("issued_at")
  expiresAt        DateTime?        @map("expires_at")
  producedAt       DateTime?        @map("produced_at")
  readyAt          DateTime?        @map("ready_at")
  deliveredAt      DateTime?        @map("delivered_at")
  createdBy        String           @map("created_by") @db.VarChar(36)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  request        Request           @relation(fields: [requestId], references: [id], onDelete: Restrict)
  subjectUser    User?             @relation("UserCredential", fields: [subjectUserId], references: [id], onDelete: SetNull)
  events         CredentialEvent[]
  deliveryRecord DeliveryRecord?
  custodyRecord  CustodyRecord?

  @@index([status])
  @@index([credentialType])
  @@index([subjectUserId])
  @@map("credentials")
}

model CustodyRecord {
  id             String    @id @default(uuid())
  credentialId   String    @unique @map("credential_id")
  subjectUserId  String    @map("subject_user_id") @db.VarChar(36)
  documentType   String    @map("document_type") @db.VarChar(50)
  documentNumber String    @map("document_number") @db.VarChar(50)
  depositTime    DateTime  @default(now()) @map("deposit_time")
  returnTime     DateTime? @map("return_time")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  credential  Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  subjectUser User       @relation("UserCustody", fields: [subjectUserId], references: [id], onDelete: Restrict)

  @@index([subjectUserId])
  @@map("custody_records")
}

model CredentialEvent {
  id           String            @id @default(uuid())
  credentialId String            @map("credential_id")
  eventType    EventType         @map("event_type")
  fromStatus   CredentialStatus? @map("from_status")
  toStatus     CredentialStatus  @map("to_status")
  actorUserId  String?           @map("actor_user_id") @db.VarChar(36)
  comment      String?           @db.Text
  occurredAt   DateTime          @default(now()) @map("occurred_at")

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, occurredAt])
  @@map("credential_events")
}

model DeliveryRecord {
  id                       String    @id @default(uuid())
  credentialId             String    @unique @map("credential_id")
  deliveredByUserId        String    @map("delivered_by_user_id") @db.VarChar(36)
  receivedByName           String    @map("received_by_name") @db.VarChar(120)
  receivedByIdentification String    @map("received_by_identification") @db.VarChar(80)
  deliveredAt              DateTime  @map("delivered_at")
  observations             String?   @db.Text
  correctedAt              DateTime? @map("corrected_at")
  correctionReason         String?   @map("correction_reason") @db.Text

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@map("delivery_records")
}

// ─────────────────────────────────────────────
// 10. NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id") @db.VarChar(36)
  type       String    @db.VarChar(80)
  title      String    @db.VarChar(255)
  message    String    @db.Text
  entityType String?   @map("entity_type") @db.VarChar(60)
  entityId   String?   @map("entity_id") @db.VarChar(36)
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// 11. AUDIT (immutable log)
// ─────────────────────────────────────────────

model AuditEvent {
  id             String   @id @default(uuid())
  actorUserId    String?  @map("actor_user_id") @db.VarChar(36)
  actorCompanyId String?  @map("actor_company_id") @db.VarChar(36)
  action         String   @db.VarChar(100)
  aggregateType  String   @map("aggregate_type") @db.VarChar(60)
  aggregateId    String?  @map("aggregate_id") @db.VarChar(36)
  previousData   Json?    @map("previous_data")
  newData        Json?    @map("new_data")
  metadata       Json?
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  correlationId  String?  @map("correlation_id") @db.VarChar(36)
  occurredAt     DateTime @default(now()) @map("occurred_at")

  @@index([aggregateType, aggregateId])
  @@index([actorUserId])
  @@index([action, occurredAt])
  @@index([occurredAt])
  @@map("audit_events")
}

// ─────────────────────────────────────────────
// 12. IDEMPOTENCY
// ─────────────────────────────────────────────

model IdempotencyRecord {
  id           String   @id @default(uuid())
  key          String   @unique @db.VarChar(120)
  actorUserId  String?  @map("actor_user_id") @db.VarChar(36)
  requestPath  String   @map("request_path") @db.VarChar(255)
  statusCode   Int      @map("status_code")
  responseBody Json?    @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([actorUserId])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// ─────────────────────────────────────────────
// 13. WORKFLOW ENGINE (DYNAMIC & VERSIONED)
// ─────────────────────────────────────────────

model WorkflowDefinition {
  id              String         @id @default(uuid())
  key             String         @unique @db.VarChar(100)
  name            String         @db.VarChar(200)
  description     String?        @db.Text
  requestType     RequestType?   @map("request_type")
  status          WorkflowStatus @default(DRAFT)
  createdByUserId String         @map("created_by_user_id") @db.VarChar(36)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  createdByUser User              @relation("WorkflowDefinitionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  versions      WorkflowVersion[]

  @@index([key])
  @@index([requestType])
  @@map("workflow_definitions")
}

model WorkflowVersion {
  id                   String         @id @default(uuid())
  workflowDefinitionId String         @map("workflow_definition_id")
  versionNumber        Int            @map("version_number")
  status               WorkflowStatus @default(DRAFT)
  schemaVersion        Int            @default(1) @map("schema_version")
  definitionJson       Json           @map("definition_json")
  checksum             String         @db.VarChar(64)
  createdByUserId      String         @map("created_by_user_id") @db.VarChar(36)
  publishedByUserId    String?        @map("published_by_user_id") @db.VarChar(36)
  createdAt            DateTime       @default(now()) @map("created_at")
  publishedAt          DateTime?      @map("published_at")

  workflowDefinition WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  createdByUser      User               @relation("WorkflowVersionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  publishedByUser    User?              @relation("WorkflowVersionPublisher", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  instances          WorkflowInstance[]

  @@unique([workflowDefinitionId, versionNumber])
  @@index([status])
  @@map("workflow_versions")
}

model WorkflowInstance {
  id                String                 @id @default(uuid())
  requestId         String                 @unique @map("request_id")
  workflowVersionId String                 @map("workflow_version_id")
  status            WorkflowInstanceStatus @default(ACTIVE)
  contextJson       Json                   @map("context_json")
  startedAt         DateTime               @default(now()) @map("started_at")
  completedAt       DateTime?              @map("completed_at")
  cancelledAt       DateTime?              @map("cancelled_at")
  lockVersion       Int                    @default(1) @map("lock_version")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  request         Request                @relation(fields: [requestId], references: [id], onDelete: Restrict)
  workflowVersion WorkflowVersion        @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  nodeInstances   WorkflowNodeInstance[]
  tasks           WorkflowTask[]
  transitions     WorkflowTransition[]

  @@index([status])
  @@map("workflow_instances")
}

model WorkflowNodeInstance {
  id                 String                     @id @default(uuid())
  workflowInstanceId String                     @map("workflow_instance_id")
  nodeKey            String                     @map("node_key") @db.VarChar(100)
  nodeType           String                     @map("node_type") @db.VarChar(50)
  status             WorkflowNodeInstanceStatus @default(PENDING)
  inputJson          Json?                      @map("input_json")
  outputJson         Json?                      @map("output_json")
  startedAt          DateTime                   @default(now()) @map("started_at")
  completedAt        DateTime?                  @map("completed_at")
  failedAt           DateTime?                  @map("failed_at")
  errorCode          String?                    @map("error_code") @db.VarChar(80)
  errorMessage       String?                    @map("error_message") @db.Text
  attemptNumber      Int                        @default(1) @map("attempt_number")

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  tasks            WorkflowTask[]

  @@index([workflowInstanceId, nodeKey])
  @@map("workflow_node_instances")
}

model WorkflowTask {
  id                 String                 @id @default(uuid())
  workflowInstanceId String                 @map("workflow_instance_id")
  nodeInstanceId     String                 @map("node_instance_id")
  status             WorkflowTaskStatus     @default(PENDING)
  assignmentType     WorkflowAssignmentType @default(ROLE) @map("assignment_type")
  assignedUserId     String?                @map("assigned_user_id") @db.VarChar(36)
  assignedRoleCode   String?                @map("assigned_role_code") @db.VarChar(60)
  assignedCompanyId  String?                @map("assigned_company_id") @db.VarChar(36)
  claimedByUserId    String?                @map("claimed_by_user_id") @db.VarChar(36)
  dueAt              DateTime?              @map("due_at")
  completedByUserId  String?                @map("completed_by_user_id") @db.VarChar(36)
  completedAt        DateTime?              @map("completed_at")
  outcome            String?                @db.VarChar(80)
  comment            String?                @db.Text
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  workflowInstance WorkflowInstance     @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeInstance     WorkflowNodeInstance @relation(fields: [nodeInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
  @@index([status])
  @@index([assignedRoleCode])
  @@index([assignedUserId])
  @@map("workflow_tasks")
}

model WorkflowTransition {
  id                 String   @id @default(uuid())
  workflowInstanceId String   @map("workflow_instance_id")
  sourceNodeKey      String   @map("source_node_key") @db.VarChar(100)
  targetNodeKey      String   @map("target_node_key") @db.VarChar(100)
  action             String   @db.VarChar(80)
  actorUserId        String?  @map("actor_user_id") @db.VarChar(36)
  taskId             String?  @map("task_id") @db.VarChar(36)
  idempotencyKey     String?  @map("idempotency_key") @db.VarChar(120)
  metadataJson       Json?    @map("metadata_json")
  createdAt          DateTime @default(now()) @map("created_at")

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@unique([workflowInstanceId, idempotencyKey])
  @@index([workflowInstanceId])
  @@map("workflow_transitions")
}
